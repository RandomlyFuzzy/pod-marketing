# --- eBay API Credentials ---
# Get these from https://developer.ebay.com/
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id
EBAY_OAUTH_TOKEN=your-ebay-oauth-token

# --- Etsy API Credentials ---
# Get these from https://www.etsy.com/developers/
ETSY_API_KEY=your-etsy-api-key
ETSY_API_SECRET=your-etsy-api-secret
ETSY_ACCESS_TOKEN=your-etsy-access-token

# --- Printify API Credentials ---
# Get token from https://developers.printify.com/
PRINTIFY_API_TOKEN=your-printify-api-token
PRINTIFY_SHOP_ID=your-printify-shop-id
